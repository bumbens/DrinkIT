<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
  x:Class="DrinkIT.Views.AllDrinksPage"
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

  <Grid Padding="16">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <VerticalStackLayout Grid.Row="0" Spacing="8">
        <Button Text="Show filters"
                Clicked="OnShowFilterClicked"
                BackgroundColor="#1E3A5F"
                TextColor="White" />
        <Picker x:Name="LetterPicker"
                Title="Select letter"
                SelectedIndexChanged="OnLetterSelected" />
    </VerticalStackLayout>

    <CollectionView Grid.Row="1"
        ItemsSource="{Binding AllDrinks}"
        SelectionChanged="OnDrinkSelected"
        SelectionMode="Single">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Label Padding="8" Text="{Binding StrDrink}" />
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

    <!-- Filter overlay -->
    <Grid Grid.RowSpan="2"
          IsVisible="{Binding IsFilterVisible}"
          BackgroundColor="#80000000">
        <VerticalStackLayout
            BackgroundColor="White"
            Padding="16"
            VerticalOptions="Center"
            Margin="32">
            <Label Text="Filter by alcohol" FontAttributes="Bold" />
            <Button Text="All" 
                    Clicked="OnAllClicked" 
                    Margin="0,8,0,0"
                    BackgroundColor = "#1E3A5F"/>
            <Button Text="Alcoholic" 
                    Clicked="OnFilterAlcoholicClicked"
                    Margin="0,8,0,0" 
                    BackgroundColor = "#1E3A5F"/>
            <Button Text="Non-alcoholic" 
                    Margin="0,8,0,0"
                    Clicked="OnFilterNonAlcoholicClicked"
                    BackgroundColor = "#1E3A5F"/>
            <Button Text="Close" 
                    Clicked="OnHideFilterClicked" 
                    Margin="0,8,0,0"
                    BackgroundColor = "#1E3A5F"/>
        </VerticalStackLayout>
    </Grid>
  </Grid>
</ContentPage>